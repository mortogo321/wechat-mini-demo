<view class="container">
  <view class="list">
    <view class="list-item" wx:for="{{items}}" wx:key="name" data-url="{{item.url}}" bindtap="navigateTo">
      <view><text class="item-name">{{item.name}}</text><text class="item-desc">{{item.desc}}</text></view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
