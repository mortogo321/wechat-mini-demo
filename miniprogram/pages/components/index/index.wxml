<view class="container">
  <view class="list">
    <view
      class="list-item"
      wx:for="{{components}}"
      wx:key="name"
      data-url="{{item.url}}"
      bindtap="navigateTo"
    >
      <view class="item-content">
        <text class="item-name">{{item.name}}</text>
        <text class="item-desc">{{item.desc}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
