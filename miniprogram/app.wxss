/* Global Styles - WeUI Extended */
@import 'weui.wxss';

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333333;
}

.container {
  padding: 20rpx;
}

.section {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  border-bottom: 1rpx solid #eeeeee;
  color: #333333;
}

.section-content {
  padding: 24rpx;
}

.btn-primary {
  background: #07C160;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.btn-default {
  background: #f5f5f5;
  color: #333333;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.result-box {
  background: #f8f8f8;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #666666;
  word-break: break-all;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
}

.gap-20 {
  gap: 20rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}
